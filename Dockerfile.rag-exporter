FROM node:20-alpine
WORKDIR /app
COPY . /app/
RUN npm ci --omit=dev 2>/dev/null || true
EXPOSE 9091
HEALTHCHECK --interval=30s --timeout=5s CMD node -e "require('http').get('http://localhost:9091/health', r => process.exit(r.statusCode===200?0:1))" || true
CMD ["node", "/app/scripts/start-rag-metrics.mjs"]

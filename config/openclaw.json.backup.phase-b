  },
  "logging": {
    "level": "debug",
    "redactSensitive": "tools"
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF4500"
      }
    }
  },
  "auth": {
    "profiles": {
      "anthropic:manual": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "models": {
    "providers": {
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "apiKey": "AIzaSyCAtgbRJ4caxBpeiTl8XhsaiCk9g3s3iV4",
        "api": "google-generative-ai",
        "models": [
          {
            "id": "gemini-2.0-flash",
            "name": "Gemini 2.0 Flash",
            "api": "google-generative-ai",
            "reasoning": false,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 1048576,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      },
      "models": {
        "anthropic/claude-haiku-4-5-20251001": {},
        "anthropic/claude-opus-4-6": {},
        "anthropic/claude-sonnet-4-6": {}
      },
      "workspace": "/home/node/projects",
      "compaction": {
        "mode": "safeguard"
      },
      "elevatedDefault": "ask",
      "timeoutSeconds": 300,
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main",
        "tools": {
          "elevated": {
            "enabled": true
          },
          "exec": {
            "security": "full",
            "ask": "off"
          },
          "fs": {
            "workspaceOnly": true
          }
        },
        "model": "anthropic/claude-opus-4-6"
      },
      {
        "id": "code-review",
        "name": "code-review",
        "workspace": "/home/node/.openclaw/workspace-code-review",
        "agentDir": "/home/node/.openclaw/agents/code-review/agent",
        "tools": {
          "fs": {
            "workspaceOnly": true
          }
        },
        "model": "anthropic/claude-opus-4-6"
      },
      {
        "id": "monitor",
        "name": "monitor",
        "workspace": "/home/node/.openclaw/workspace-monitor",
        "agentDir": "/home/node/.openclaw/agents/monitor/agent",
        "tools": {
          "elevated": {
            "enabled": true
          },
          "exec": {
            "security": "full",
            "ask": "off"
          },
          "fs": {
            "workspaceOnly": true
          }
        },
        "model": "anthropic/claude-sonnet-4-6"
      }
    ]
  },
  "tools": {
    "allow": [
      "group:runtime",
      "group:fs",
      "group:web",
      "memory_search",
      "memory_get"
    ],
    "web": {
      "search": {
        "enabled": true,
        "provider": "brave",
        "maxResults": 5,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      },
      "fetch": {
        "enabled": true,
        "maxChars": 50000,
        "timeoutSeconds": 30,
        "cacheTtlMinutes": 15
      }
    },
    "elevated": {
      "enabled": true
    },
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off",
      "node": "Mac-mini"
    }
  },
  "messages": {
